{
  "expo": {
    "name": "GlobiPet",
    "slug": "globipet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "globipet",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#E65100"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.globipet.app",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E65100"
      },
      "package": "com.globipet.app",
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.NFC",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.VIBRATE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "react-native-nfc-manager",
        {
          "selectIdentifiers": [],
          "systemCodes": []
        }
      ],
      "react-native-edge-to-edge",
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fb18039a-36c8-4c24-af71-6f4853701cf9"
      },
      "googleAndroidClientId": "26367014154-qpuq57e38vai00t19ph01cvchh600pgm.apps.googleusercontent.com",
      "googleIosClientId": "26367014154-8aqhrgd9l9nr6brcjimfgahnq095vpvu.apps.googleusercontent.com",
      "googleWebClientId": "26367014154-8aqhrgd9l9nr6brcjimfgahnq095vpvu.apps.googleusercontent.com"
    }
  }
}
