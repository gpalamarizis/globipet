{
  "expo": {
    "name": "GlobiPet",
    "slug": "globipet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "globipet",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#E65100"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.globipet.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Χρειαζόμαστε την τοποθεσία σας για να εντοπίσουμε κατοικίδια κοντά σας.",
        "NSLocationAlwaysUsageDescription": "Χρειαζόμαστε πάντα πρόσβαση στην τοποθεσία για το GPS tracker του κατοικίδιού σας.",
        "NSCameraUsageDescription": "Χρειαζόμαστε πρόσβαση στην κάμερα για να φωτογραφίσετε το κατοικίδιό σας.",
        "NSPhotoLibraryUsageDescription": "Χρειαζόμαστε πρόσβαση στις φωτογραφίες σας."
      },
      "config": {
        "googleMapsApiKey": "YOUR_IOS_MAPS_KEY"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E65100"
      },
      "package": "com.globipet.app",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ],
      "config": {
        "googleMaps": { "apiKey": "YOUR_ANDROID_MAPS_KEY" }
      }
    },
    "web": { "bundler": "metro", "output": "static" },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      ["expo-notifications", { "icon": "./assets/notification-icon.png", "color": "#E65100" }],
      ["expo-location", { "locationAlwaysAndWhenInUsePermission": "Allow GlobiPet to use your location." }]
    ],
    "experiments": { "typedRoutes": true },
    "extra": {
      "eas": { "projectId": "YOUR_EAS_PROJECT_ID" }
    }
  }
}
